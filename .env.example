# Docker(MSSQL)
MSSQL_SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MSSQL_PORT=1433

# Backend DB
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=mini_mes;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# CORS 허용 출처(쉼표 구분)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5500

# API 보안(운영 권장)
APP_REQUIRE_API_KEY=true
APP_API_KEY=CHANGE_ME_32BYTE_RANDOM_KEY
APP_WRITE_ROLES=ROLE_ADMIN,ROLE_OPERATOR
